# ============================================
# 测试环境变量配置
# ============================================
# 使用方法：
# 1. 复制本文件为 .env.test
# 2. 根据需要修改配置
# 3. 确保测试数据库已存在（会自动创建 schema）
# ============================================

# 环境标识（必须为 test，框架据此判断测试模式）
ENVIRONMENT=test

# ============================================
# MySQL 测试数据库配置
# 注意：框架会自动附加 _test 后缀
# 例如：DATABASE_SCHEMA=rongtongjin → 实际使用 rongtongjin_test
# ============================================
DATABASE_TYPE=mysql
DATABASE_HOST=127.0.0.1
DATABASE_PORT=3306
DATABASE_USER=root
DATABASE_PASSWORD=123456
DATABASE_SCHEMA=rongtongjin
DATABASE_CHARSET=utf8mb4

# 数据库调试（测试环境建议关闭）
DATABASE_ECHO=false
DATABASE_POOL_ECHO=false

# ============================================
# Redis 测试数据库配置（建议使用独立的 DB 编号）
# ============================================
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=1

# ============================================
# Token 密钥
# ============================================
TOKEN_SECRET_KEY=test-secret-key-for-integration-tests-only
